{
  "functions": {
    "api/test-simulation.js": { "maxDuration": 60 },
    "api/community-*.js": { "maxDuration": 30 },
    "api/advisor.js": { "maxDuration": 280 },
    "api/chat.js": { "maxDuration": 280 }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
