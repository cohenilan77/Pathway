# Copy this file to .env and fill in your key
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_api_key_here

# Access code consultants must enter to reach the admin portal
ADMIN_SECRET=choose_a_strong_admin_passphrase

# Email address of the single Super Admin account. Required in production —
# the app will refuse to start without it. See SUPER_ADMIN_INITIAL_PASSWORD below.
SUPER_ADMIN_EMAIL=cohenilan@gmail.com

# Preview/development bootstrap only. If set, this creates/updates the
# SUPER_ADMIN_EMAIL address as a normal authenticated Super Admin user on first
# login/admin-user load.
# Do not configure this in Production until reviewed and approved.
SUPER_ADMIN_INITIAL_PASSWORD=

# Upstash Redis (via Vercel Marketplace integration, or any Upstash Redis REST credentials)
# Used to persist registered users and their sessions across devices.
# If left unset, the app falls back to a local JSON file store (.data/devdb.json) for development only.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend (https://resend.com) — used to send the "Send Inquiry" contact form email.
# Get your key from the Resend dashboard under API Keys.
RESEND_API_KEY=

# Vercel Blob — used to store original uploaded PDF/DOCX files.
# Vercel creates this automatically when a Blob store is connected to the project.
BLOB_READ_WRITE_TOKEN=

# OAuth sign-in. These must also be added in Vercel Project Settings > Environment Variables.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Also accepted for Google OAuth if you already used these names elsewhere:
# GOOGLE_ID=
# GOOGLE_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Optional: force OAuth callbacks to one canonical deployed origin.
# In Vercel this can usually be left empty because VERCEL_PROJECT_PRODUCTION_URL is enabled.
OAUTH_REDIRECT_ORIGIN=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
